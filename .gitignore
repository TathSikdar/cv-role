# Tectonic build artifacts
*.log
*.aux
*.out
*.synctex.gz

# Python
__pycache__/
*.pyc

# Generated CVs are committed on purpose — they are the deliverable.
# Extracted text is a derived intermediate.
build/*/*.txt

config/job-listings/
*.tex
# The templates under config/ are SOURCE, not build output. cv-template.tex was
# grandfathered in before the *.tex rule above existed; without this negation a
# new template is silently untracked and the repo does not build after a clone.
!config/*.tex
*.pdf
*.log
cover-letters/*